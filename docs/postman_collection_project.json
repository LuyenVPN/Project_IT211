{
  "info": {
    "name": "Project API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for hospital project endpoints. Responses follow {success,message,data} where implemented."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - Cap phat JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.data && body.data.accessToken) pm.environment.set('accessToken', body.data.accessToken);",
                  "if (body.data && body.data.refreshToken) pm.environment.set('refreshToken', body.data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{patientUsername}}\",\n  \"password\": \"{{patientPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Login Doctor - Lay doctorAccessToken",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.data && body.data.accessToken) pm.environment.set('doctorAccessToken', body.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
