            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "diagnosis", "type": "text", "value": "Diagnosis text" },
                { "key": "ownerId", "type": "text", "value": "{{ownerId}}" }
              ]
            }
          }
        }
      ]
    },
